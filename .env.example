# OpenRouter API key used for the optional LLM drafting layer.
# The service runs fully (rule-only) even if this is unset or invalid.
OPENROUTER_API_KEY=

# OpenRouter model slug used for language understanding and text drafting.
MODEL_NAME=google/gemini-2.0-flash-001

# Hard cap (seconds) for the single LLM round-trip before falling back to rules.
LLM_TIMEOUT_SECONDS=12

# Local/Docker server port (Vercel ignores this).
PORT=8000
